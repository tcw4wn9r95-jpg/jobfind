# Required — powers CV analysis, job matching, CV generation and chat
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the Claude model used (defaults to claude-sonnet-5)
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional — store generated CVs in Google Drive.
# Create a Google Cloud service account with the Drive API enabled, download its
# JSON key, then either paste the JSON inline or point to the file:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# Share a Drive folder with the service account's email and put its ID here:
# GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGh...
